# Copy to .env and fill in. Do NOT commit .env.

# --- LiteLLM gateway (KIT/DSI, supervisor-provided) -------------------------
# ALL LLM traffic goes through this OpenAI-compatible proxy. Key starts with "sk-".
LITELLM_API_KEY=sk-...
# Default is set in config.yaml; uncomment if you ever need to override.
# LITELLM_BASE_URL=https://ai-gateway.dsi-experimente.de/v1

# --- HuggingFace (optional) -------------------------------------------------
# Only needed if a gated dataset/model is added later. Public DeBERTa-MNLI does
# not require a token. Public HotpotQA / framolfese 2Wiki do not require one.
HF_TOKEN=

# --- Spend guard ------------------------------------------------------------
# Soft cap surfaced to scripts. Real budget is enforced server-side by the
# gateway against your key. Pilot brief allows ~$150.
SPEND_LIMIT_USD=150
