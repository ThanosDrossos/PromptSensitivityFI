# Copy to .env and fill in. Do NOT commit .env.
# OpenAI: GPT-4o + text-embedding-3-large + paraphrase generation.
OPENAI_API_KEY=sk-...

# Together.ai: Llama-3.1-8B, Mistral-7B-v0.3, Qwen2.5-7B (open-weight inference).
TOGETHER_API_KEY=...

# HuggingFace token, only required if downloading gated models (DeBERTa-MNLI is open).
HF_TOKEN=

# Optional: cap on USD that pipeline will spend before aborting (Sprint 5 budget guard).
SPEND_LIMIT_USD=150
